# Helbreath.xyz Server Configuration
# Copy this file to .env and customize for your environment

# JWT signing secret — CHANGE THIS IN PRODUCTION
JWT_SECRET=helbreath-xyz-change-this-to-a-random-64-char-secret

# JWT token expiration (Go duration format: 24h, 48h, 720h for 30 days)
JWT_EXPIRY=24h

# Database connection URL
DATABASE_URL=postgres://hbonline:hbonline@localhost:5432/hbonline?sslmode=disable

# Server listen address
ADDR=:8080

# Map data directory
MAP_DIR=assets/MAPDATA

# Use in-memory store (set to "true" for development without PostgreSQL)
MEMDB=false
