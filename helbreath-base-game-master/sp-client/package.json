{
    "name": "helbreath-sp-client",
    "description": "Browser-based single-player Helbreath base client built with Phaser 3 and React.",
    "version": "0.8.0",
    "author": "Erko Knoll",
    "license": "MIT",
    "licenseUrl": "https://github.com/ErkoKnoll/helbreath-base-game/LICENSE",
    "homepage": "https://github.com/ErkoKnoll/helbreath-base-game",
    "keywords": [
        "helbreath",
        "base-game",
        "browser-game",
        "single-player",
        "rpg",
        "mmorpg",
        "phaser",
        "phaser3",
        "react",
        "vite",
        "typescript"
    ],
    "scripts": {
        "dev": "vite --config vite/config.dev.mjs",
        "build": "vite build --config vite/config.prod.mjs",
        "dev-nolog": "vite --config vite/config.dev.mjs",
        "build-nolog": "vite build --config vite/config.prod.mjs",
        "compress-assets": "node ../tools/compress-assets.js --ratio=1",
        "compress-assets:fast": "node ../tools/compress-assets.js --ratio=1",
        "compress-assets:best": "node ../tools/compress-assets.js --ratio=9"
    },
    "dependencies": {
        "@babel/runtime": "^7.28.6",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/utilities": "^3.2.2",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-switch": "^1.2.6",
        "@tanstack/react-store": "^0.8.0",
        "@uiw/react-color-sketch": "^2.9.5",
        "fflate": "^0.8.2",
        "npm": "^11.8.0",
        "phaser": "^3.90.0",
        "promise-throttle-all": "^1.1.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@vitejs/plugin-react": "^4.3.4",
        "eslint": "^9.22.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "globals": "^16.0.0",
        "terser": "^5.28.1",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.26.1",
        "vite": "^6.3.1",
        "wrangler": "^4.66.0"
    }
}
